# A name that does not resolve to any entry in the merged view.
#
# Contract (exit 3):
#   - Exit code 3. Stable.
#   - stderr names the audience scope that was searched (audience bucket
#     and shared bucket).

! exec taskgate show no-such-task
! stdout .
stderr 'not found'
stderr '\.taskgate/human'
stderr '\.taskgate/shared'

-- .taskgate/human/build --
#!/bin/sh
# ---
# summary: Build.
# ---
echo build
