# `taskgate ai show <name>` for a task emits a single `task` envelope.
#
# Contract (task shape):
#   {
#     "kind":     "task",                          // required, literal
#     "path":     string,                          // real physical path under .taskgate/
#     "summary":  string | null,                   // null when no annotation; never omitted
#     "body":     string,                          // omitted when no body; never null
#     "audience": "human" | "ai"                   // required
#   }
# Compact JSON, terminated by exactly one trailing \n.

exec taskgate ai show analyze
stdout '"kind":"task"'
stdout '"path":"\.taskgate/ai/analyze"'
stdout '"summary":"Analyze the codebase\."'
stdout '"body":"Reads CONFIG from the environment\."'
stdout '"audience":"ai"'
! stderr .

-- .taskgate/ai/analyze --
#!/bin/sh
# ---
# summary: Analyze the codebase.
# body: |
#   Reads CONFIG from the environment.
# ---
echo analyze
