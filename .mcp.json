{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_MCP_ACCESS_TOKEN}",
        "-e",
        "GITHUB_TOOLSETS=issues,pull_requests,projects",
        "ghcr.io/github/github-mcp-server"
      ]
    },
    "agent-sandbox": {
      "command": "agent-sandbox",
      "args": ["command-router"]
    }
  }
}
