{
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "TERM",
      "LANG",
      "LC_ALL",
      "USER",
      "__MISE*",
      "MISE*",
      "GO*",
      "UV_CACHE_DIR",
    ],
  },
  "extends": "claude",
  "filesystem": {
    // don't place private keys in ~/.ssh
    "bypass_protection": ["~/.docker", "~/.ssh"],
    "read": [
      "~/.orbstack",
      "~/.taskgate",
      "~/.docker",
      "~/.local/share/mise",
      "~/.ssh",
      "~/.config/gh",
    ],
    "allow_file": ["/dev/null", "~/.ssh/known_hosts"],
  },
  "meta": {
    "name": "custom claude",
  },
  "groups": {
    "include": ["go_runtime"],
  },
}
